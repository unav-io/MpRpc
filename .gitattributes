# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Explicitly text
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Binary — never touch
*.dll   binary
*.pdb   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.zip   binary
*.exe   binary
*.patch binary
